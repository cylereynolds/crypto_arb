# Python virtual environment
.venv/
venv/
env/

# Secrets / credentials / API keys  (POC is keyless, but never commit these)
.env
.env.*
*.pem
*.key
*_key
*_secret
*.secret
*.credentials
credentials.json
secrets.json
api_keys.json
keys.json

# Python caches
__pycache__/
*.py[cod]
*.egg-info/

# OS cruft
.DS_Store
Thumbs.db

# Plots / scratch output
*.png
*.tmp

# Local data cache — regenerable via collect_funding.py / funding_scanner.py.
# The full funding scan grows this past GitHub's 100MB file limit, so it is a
# local cache only. funding_scan.csv (the scan RESULTS) stays tracked.
*.db
*.db-wal
*.db-shm
*.db-journal

# Scan / server logs
*.log
